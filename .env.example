# Service
SERVICE_NAME=school-management
ENV=production
USER_PORT=5111
ADMIN_PORT=5222

# Redis (overridden by docker-compose for container networking)
REDIS_URI=redis://127.0.0.1:6379
CORTEX_REDIS=redis://127.0.0.1:6379
CORTEX_PREFIX=school
CORTEX_TYPE=school-management
OYSTER_REDIS=redis://127.0.0.1:6379
OYSTER_PREFIX=school
CACHE_REDIS=redis://127.0.0.1:6379
CACHE_PREFIX=school:ch

# MongoDB (overridden by docker-compose for container networking)
MONGO_URI=mongodb://localhost:27017/school-management

# Secrets (CHANGE THESE for production — generate with: openssl rand -hex 32)
LONG_TOKEN_SECRET=your-long-token-secret-here
SHORT_TOKEN_SECRET=your-short-token-secret-here
NACL_SECRET=your-nacl-secret-base64-here

# Logging
LOG_LEVEL=info
